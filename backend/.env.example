DATABASE_URL=postgresql://aisolutioncrm:aisolutioncrm_dev_pw@localhost:5432/aisolutioncrm_dev
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# S3-compatible object storage (Hetzner Object Storage in prod). Leave
# S3_ENDPOINT_URL unset to use real AWS S3; set it for Hetzner/MinIO/etc.
S3_ENDPOINT_URL=
S3_REGION=us-east-1
S3_BUCKET=aisolutioncrm-files
S3_ACCESS_KEY=dev-access-key
S3_SECRET_KEY=dev-secret-key
S3_PUBLIC_URL_BASE=
